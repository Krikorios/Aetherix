<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal per-machine WiX 4 source for the Aetherix agent service.
  Built by agent/packaging/windows-sign.ps1.

  Note: this template intentionally avoids interactive features. The agent
  installs as a NT service, runs as LocalSystem, and starts on boot. The
  service binary path is interpolated by the build script via the
  AgentBinaryPath preprocessor variable.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Aetherix Agent"
           Manufacturer="Aetherix Security Inc."
           Version="$(Version)"
           UpgradeCode="2C6D89F4-8D5B-4D69-8E7B-3F9F11A8D3F1"
           Scope="perMachine"
           Compressed="yes"
           InstallerVersion="500">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="AetherixDir" Name="Aetherix">
        <Component Id="AgentBinary" Guid="*" Bitness="always64">
          <File Id="AgentExe"
                Source="$(AgentBinaryPath)"
                Name="aetherix-agent.exe"
                KeyPath="yes" />
          <ServiceInstall Id="AetherixSvc"
                          Name="AetherixAgent"
                          DisplayName="Aetherix Agent"
                          Description="Aetherix DLP and EDR enforcement agent."
                          Type="ownProcess"
                          Start="auto"
                          ErrorControl="normal"
                          Account="LocalSystem"
                          Vital="yes" />
          <ServiceControl Id="AetherixSvcStart"
                          Name="AetherixAgent"
                          Start="install"
                          Stop="both"
                          Remove="uninstall"
                          Wait="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="Aetherix Agent" Level="1">
      <ComponentRef Id="AgentBinary" />
    </Feature>
  </Package>
</Wix>
